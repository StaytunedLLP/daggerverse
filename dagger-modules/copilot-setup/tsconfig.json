{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "paths": {
      "*": [
        "./*"
      ],
      "@dagger.io/dagger": [
        "./sdk"
      ],
      "@dagger.io/dagger/telemetry": [
        "./sdk/telemetry"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}