{
  "name": "@staytunedllp/daggerverse",
  "version": "1.2.0",
  "description": "Shared TypeScript helpers for Staytuned Dagger modules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "imports": {
    "#*": {
      "types": "./src/*",
      "default": "./dist/*"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npx -p typescript@7.0.2 tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "echo 'No lint check required for daggerverse'",
    "format:check": "echo 'No format check required for daggerverse'",
    "test": "echo 'No tests defined for daggerverse'",
    "verify:incremental": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@dagger.io/dagger": "^0.21.7"
  },
  "devDependencies": {
    "@dagger.io/dagger": "^0.21.7",
    "@types/node": "^24.0.0"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
